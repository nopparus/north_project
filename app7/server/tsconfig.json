{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "esModuleInterop": true,
        "strict": false,
        "skipLibCheck": true,
        "types": [
            "node"
        ],
        "allowImportingTsExtensions": true,
        "noEmit": true
    },
    "include": [
        "**/*.ts"
    ]
}